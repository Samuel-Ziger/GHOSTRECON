# Usa o MESMO .env que o GHOSTRECON (copiar/colar o ficheiro para esta pasta
# OU deixar o .env só na pasta do monorepo e exportar antes do cron):
#   export GHOSTRECON_ENV_FILE=/caminho/absoluto/para/GHOSTRECON/.env

# ─── Opcional: ficheiro .env explícito (útil para cron) ───
# GHOSTRECON_ENV_FILE=/opt/GHOSTRECON/.env

# Se vps-recon-workflow não estiver dentro da pasta GHOSTRECON, apontar a raiz do clone:
# GHOSTRECON_REPO_ROOT=/opt/GHOSTRECON

# ─── Persistência recon (motor embutido) — igual ao GHOSTRECON ───
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Lista de domínios (sync; por defeito o subdomains.txt na raiz do GHOSTRECON: ../subdomains.txt) ───
WORKFLOW_DOMAIN_SOURCE=table
WORKFLOW_DOMAINS_TABLE=workflow_domains
WORKFLOW_DOMAIN_COLUMN=domain
WORKFLOW_ROOT_DOMAIN_COLUMN=root_domain

WORKFLOW_DOMAINS_FILE=../subdomains.txt
WORKFLOW_SKIP_SUPABASE_SYNC=0

WORKFLOW_EXACT_MATCH=subdomain_only

WORKFLOW_PLAYBOOK=subdomain-hunt
WORKFLOW_PROFILE=standard
WORKFLOW_OPSEC_PROFILE=aggressive
WORKFLOW_KALI_MODE=1
WORKFLOW_CONFIRM_ACTIVE=1
WORKFLOW_AUTO_AI_REPORTS=0
WORKFLOW_SQLITE_PATH=./data/workflow-state.db

# Opcional Gemini primeiro; se falhar, OpenRouter (mesmas chaves do GHOSTRECON):
# GEMINI_API_KEY=  ou GOOGLE_AI_API_KEY=
# OPENROUTER_API_KEY=
# GHOSTRECON_OPENROUTER_MODEL=google/gemma-2-9b-it

# Webhook: no servidor só VPS usa WORKFLOW_VPS_WEBHOOK_URL (prioritário sobre o genérico)
WORKFLOW_VPS_WEBHOOK_URL=https://exemplo.com/vps-worker
WORKFLOW_WEBHOOK_URL=https://exemplo.com/seu-endpoint
WORKFLOW_WEBHOOK_ALWAYS=0
