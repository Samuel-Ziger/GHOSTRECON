# GhostTrace — variáveis de ambiente
# (no protótipo, todas as chaves de IA são geridas via UI > Settings e persistidas em localStorage)

NEXT_PUBLIC_APP_NAME=GhostTrace
NEXT_PUBLIC_APP_VERSION=0.1.0

# FastAPI backend (opcional — sem isso, só localStorage)
# Porta 8787 evita conflito com outra instância ou reservas do Windows na 8000
NEXT_PUBLIC_API_URL=http://localhost:8787

# GHOSTRECON — UI de anotações em /anotacao (proxy da API Node)
NEXT_PUBLIC_BASE_PATH=/anotacao
