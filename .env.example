# Copiar para .env e preencher (nunca commitar .env)

# ── Postgres direto (Supabase: Settings → Database → URI ou Session Pooler para IPv4)
# A password na URL tem de estar codificada se tiver @, #, etc. (encodeURIComponent)
# Exemplo: postgresql://postgres:SENHA_ENCODADA@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=

# ── Alternativa: API Supabase (sem DATABASE_URL)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

PORT=3847

# VirusTotal — subdomínios (módulo `virustotal` na UI)
# VIRUSTOTAL_API_KEY=

# GitHub — Code Search API (módulo «GitHub leaks»); aumenta rate limit. PAT classic ou fine-grained (read)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# Estrutura de clone local (Fase 1 Shannon): ativo por padrão; clona repositórios GitHub candidatos na pasta `clone/`.
# Retenção padrão: 30 dias (1 mês), com limpeza automática no início de cada operação de clone.
# GHOSTRECON_GITHUB_CLONE_ENABLED=1
# GHOSTRECON_GITHUB_CLONE_ENABLED=0   # desativa se necessário
# GHOSTRECON_CLONE_DIR=clone
# GHOSTRECON_CLONE_MAX_REPOS=3
# GHOSTRECON_CLONE_MAX_SIZE_MB=200
# GHOSTRECON_CLONE_TIMEOUT_MS=120000
# GHOSTRECON_CLONE_RETENTION_DAYS=30

# Shannon Lite (pasta IAs/shannon) — GET /api/capabilities devolve `shannon`; UI módulo `shannon_whitebox`
# GHOSTRECON_SHANNON_HOME=/caminho/absoluto/para/IAs/shannon
# Após clone(s) GitHub, o pipeline pode executar ./shannon start (serial global) e fazer poll de workflow.log:
# GHOSTRECON_SHANNON_AUTO_RUN=0          # 1 = executar (default); 0 = só clone/diagnóstico
# GHOSTRECON_SHANNON_MAX_CLONES_PER_RUN=1
# GHOSTRECON_SHANNON_START_TIMEOUT_MS=240000
# GHOSTRECON_SHANNON_WORKFLOW_TIMEOUT_MS=5400000
# GHOSTRECON_SHANNON_PIPELINE_TESTING=1  # passa --pipeline-testing ao Shannon (mais rápido para dev)
# GHOSTRECON_SHANNON_REPORT_MAX_CHARS=120000
# Abrir automaticamente a Temporal Web UI no browser quando o CLI imprimir o URL (evento NDJSON open_url)
# GHOSTRECON_SHANNON_OPEN_TEMPORAL_UI=0
# GHOSTRECON_SHANNON_MIRROR_CLI=0        # 1 = espelhar stdout/stderr do Shannon no terminal da UI (default 1)

# PentestGPT / validação HTTP pós-recon (módulo UI `pentestgpt_validate`)
# O corpo inclui `ghostPayload` (mesmo shape que export IA). A resposta pode ter `summary`, `validatedFindings`, `falsePositives`.
# GHOSTRECON_PENTESTGPT_URL=http://127.0.0.1:8765/validate
# GHOSTRECON_PENTESTGPT_ENABLED=1
# GHOSTRECON_PENTESTGPT_TIMEOUT_MS=120000
# GHOSTRECON_PENTESTGPT_HOME=/caminho/absoluto/PentestGPT   # para GET /api/capabilities → pentestgpt (default IAs/PentestGPT)
# Ponte opcional: npm run pentestgpt-bridge — depois define GHOSTRECON_PENTESTGPT_URL=http://127.0.0.1:8765/validate
# GHOSTRECON_PENTESTGPT_BRIDGE_PORT=8765
# GHOSTRECON_PENTESTGPT_BRIDGE_MODEL=openai/gpt-4o-mini
# Prompt de sistema opcional (substitui o foco bug bounty por defeito na ponte)
# GHOSTRECON_PENTESTGPT_BRIDGE_SYSTEM_PROMPT="..."

# Relatórios IA: após cada recon, se a UI tiver «Confirmo envio» e existir chave → gera Markdown no disco
# GEMINI_API_KEY=          # ou GOOGLE_AI_API_KEY=
# OPENROUTER_API_KEY=      # segundo relatório (prioritário sobre Anthropic direct)
# GHOSTRECON_OPENROUTER_MODEL=google/gemma-4-31b-it   # slug OpenRouter; vê openrouter.ai/models
# GHOSTRECON_OPENROUTER_HTTP_REFERER=https://tua-app.local  # opcional (OpenRouter pede URL do site)
# GHOSTRECON_OPENROUTER_APP_TITLE=GHOSTRECON
# ANTHROPIC_API_KEY=       # só usado se OPENROUTER_API_KEY estiver vazio
# Modelo Gemini (cota free varia por modelo/conta; erro «limit: 0» → troca de modelo ou activa billing)
# GHOSTRECON_GEMINI_MODEL=gemini-2.5-flash
# Retentativas Gemini para 429/5xx/timeout (respeita Retry-After/backoff exponencial)
# GHOSTRECON_GEMINI_MAX_RETRIES=4
# Retentativas OpenRouter para 429/5xx/timeout (útil para picos de 429/503)
# GHOSTRECON_OPENROUTER_MAX_RETRIES=4
# Fluxo fallback em cascata (runDualAiReports): espera fixa entre tentativas Gemini (padrão 60s)
# GHOSTRECON_AI_FALLBACK_WAIT_SEC=60
# GHOSTRECON_CLAUDE_MODEL=claude-3-5-sonnet-20241022
# IA local OpenAI-compatible (LM Studio ou GHOST local) — fallback final opcional
# GHOSTRECON_LMSTUDIO_ENABLED=1
# GHOSTRECON_LMSTUDIO_BASE_URL=http://127.0.0.1:8000/v1
# GHOSTRECON_LMSTUDIO_MODEL=ghost
# GHOSTRECON_LMSTUDIO_API_KEY=lm-studio
# n_ctx do modelo no LM Studio (para orçar prompt + max_tokens)
# GHOSTRECON_LMSTUDIO_N_CTX=4096
# Máximo de tokens na resposta (capped automaticamente vs n_ctx)
# GHOSTRECON_LMSTUDIO_MAX_OUTPUT_TOKENS=1024
# GHOSTRECON_LMSTUDIO_MAX_TOKENS=1024
# Timeout do pedido HTTP (modelos locais com "reasoning" podem demorar vários minutos)
# GHOSTRECON_LMSTUDIO_TIMEOUT_MS=900000
# GHOSTRECON_LMSTUDIO_TEMPERATURE=0.25
# Limita o tamanho do JSON enviado ao LM Studio (evita erro de contexto n_ctx)
# GHOSTRECON_LMSTUDIO_MAX_INPUT_CHARS=14000
# GHOSTRECON_LMSTUDIO_CHARS_PER_TOKEN=1.45
# Sync automático para base de conhecimento local do GHOST quando um achado validado é ligado ao Cérebro (Cortex)
# GHOSTRECON_GHOST_KB_SYNC=1
# GHOSTRECON_GHOST_BASE_URL=http://127.0.0.1:8000
# GHOSTRECON_GHOST_KB_CATEGORY=ghostrecon_validated
# GHOSTRECON_GHOST_KB_TIMEOUT_MS=4500
# GHOSTRECON_AI_AUTO=0     # 1 ou omitido = IA após recon (com confirmação na UI); 0 = desliga auto (POST /api/ai-reports se precisares)
# Limite de caracteres por campo no relatório IA (prompt + truncagem; padrão 2400 / 1600)
# GHOSTRECON_AI_RELATORIO_MAX_CHARS=2400
# GHOSTRECON_AI_PROXIMOS_MAX_CHARS=1600
# Stealth global (além do módulo na UI): jitter + User-Agent rotativo em probe/verify/JS
# GHOSTRECON_STEALTH=1

# Webhook após recon: URL Discord → resumo do run + relatório IA (embeds); outro URL → JSON legado + JSON kind=ai_report após IA
# GHOSTRECON_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Após relatório IA + próximos passos: envia lista completa de achados NOVOS vs run anterior (compareRuns → added). Discord: várias mensagens; JSON: kind=recon_delta_full
# GHOSTRECON_WEBHOOK_DELTA_FULL=1
# Limite de linhas no payload (protecção; omitir = 20000)
# GHOSTRECON_WEBHOOK_DELTA_MAX_FINDINGS=5000

# ffuf (módulo kali_ffuf): menos threads = menos pico de CPU/rede no notebook (1–64, padrão 32)
# GHOSTRECON_FFUF_THREADS=8

# dirsearch (módulo kali_dirsearch): varredura recursiva ampla (pode demorar)
# GHOSTRECON_DIRSEARCH_THREADS=25
# GHOSTRECON_DIRSEARCH_MAXTIME=1800         # segundos por alvo (120–7200)
# GHOSTRECON_DIRSEARCH_RECURSION_DEPTH=8    # profundidade (1–20)

# Rotação de identidade / proxy pool (máx. 32 entradas)
# Formatos aceites por entrada:
#   - http://user:pass@host:port
#   - user:pass@host:port
#   - host:port:user:pass
#   - host:port
# GHOSTRECON_PROXY_POOL=31.59.20.176:6754:user:pass,198.23.239.134:6540:user:pass
# Estratégia: round_robin | random
# GHOSTRECON_PROXY_ROTATION=round_robin
#
# Proxychains-ng (opcional): encadeia scanners do modo Kali via SOCKS/HTTP.
# Recomendado quando queres forçar saída pela tua rotação/Tor/chains.
# GHOSTRECON_PROXYCHAINS=1
# GHOSTRECON_PROXYCHAINS_BIN=proxychains4
# GHOSTRECON_PROXYCHAINS_CONF=/etc/proxychains4.conf
# GHOSTRECON_PROXYCHAINS_QUIET=1
# Pula ferramentas específicas (CSV): nmap,ffuf,nuclei,dirsearch,dalfox,whois,sqlmap,wpscan
# GHOSTRECON_PROXYCHAINS_SKIP=

# Navegation (playbook local tools/Navegation; fallback node_modules/Navegation)
# 1 = além de mostrar checklist no run, executa automaticamente navegation.sh/py
# Recomendado começar com dry-run ligado.
# GHOSTRECON_NAVEGATION_EXEC=0
# GHOSTRECON_NAVEGATION_DRY_RUN=1
# GHOSTRECON_NAVEGATION_TIMEOUT_MS=900000

# ─── TOR ROUTING (P0) ─────────────────────────────────────────────────────────
# O playbook tools/Navegation/navegation.{sh,py} configura o /etc/tor/torrc com:
#   SocksPort 127.0.0.1:9050 IsolateDestAddr IsolateClientAuth IsolateSOCKSAuth
#   TransPort 127.0.0.1:9040
#   DNSPort   127.0.0.1:5353
#   ControlPort 127.0.0.1:9051   (CookieAuthentication 1)
# Rota recomendada: routear o pipeline pelo SOCKS5 com socks5h:// (DNS via Tor).
#
# Pool de proxies (aceita http/https/socks5/socks5h, separados por vírgula):
# GHOSTRECON_PROXY_POOL=socks5h://127.0.0.1:9050
# GHOSTRECON_PROXY_ROTATION=round_robin   # round_robin | random | fixed
#
# Quando 1 e há SOCKS no pool, gera user/pass único por target/run para activar
# IsolateSOCKSAuth (circuit dedicado por alvo). Recomendado para bug bounty.
# GHOSTRECON_TOR_ISOLATE=1
#
# Força o /api/recon/stream a abortar se o tunnel Tor não validar (IP via SOCKS5
# diferente do directo + bootstrap=done + IsTor!=false). Equivalente a passar
# tor.required=true no body. Use para evitar runs por IP claro acidentalmente.
# GHOSTRECON_TOR_REQUIRED=0
#
# ControlPort + cookie auth para tor-control.js (NEWNYM, GETINFO).
# GHOSTRECON_TOR_CONTROL_HOST=127.0.0.1
# GHOSTRECON_TOR_CONTROL_PORT=9051
# GHOSTRECON_TOR_CONTROL_COOKIE_PATH=/run/tor/control.authcookie
# GHOSTRECON_TOR_CONTROL_PASSWORD=        # alternativa ao cookie (raw, não o hash)
#
# Bridges obfs4 (lista, uma linha por bridge — copia da bridges.torproject.org)
# GHOSTRECON_TOR_BRIDGES=
# obfs4 1.2.3.4:443 ABCDEF... cert=... iat-mode=0
# obfs4 5.6.7.8:443 GHIJKL... cert=... iat-mode=0
#
# Modo "tor strict" — anti-leak central. Ver docs/TOR.md.
# Quando 1: liga proxychains4 automaticamente para todas as tools externas
# (nmap, sqlmap, curl, dig, ...), locka Node DNS para 127.0.0.1:5353,
# escreve um proxychains.conf efémero com strict_chain+proxy_dns, força
# header hygiene Tor Browser-like nos fetchs, e refuse_to_run se faltar
# qualquer pré-requisito (proxychains4, ControlPort, DNSPort, SOCKS).
# GHOSTRECON_TOR_STRICT=0
#
# Override do binary/conf (default: auto)
# GHOSTRECON_PROXYCHAINS_BIN=proxychains4
# GHOSTRECON_PROXYCHAINS_CONF=/etc/proxychains.conf
#
# Tools adicionais a wrap-ear em strict (separadas por vírgula). Ex.: "rustscan,zmap"
# GHOSTRECON_TOR_STRICT_WRAP_ADD=
# Tools a NÃO wrap-ear (mesmo defaults). Risco: vazam IP. Ex.: "curl"
# GHOSTRECON_PROXYCHAINS_SKIP=
#
# Override dos portos (apenas se mudaste no torrc)
# GHOSTRECON_TOR_SOCKS_HOST=127.0.0.1
# GHOSTRECON_TOR_SOCKS_PORT=9050
# GHOSTRECON_TOR_DNS_PORT=5353

# Rate limit POST /api/recon/stream (0 = desligado). Chave de bucket:
#   principal (sub) > x-engagement-id header > ip
# GHOSTRECON_RL_MAX=12
# GHOSTRECON_RL_WINDOW_MS=60000

# ─── AUTH / RBAC (P0) ─────────────────────────────────────────────────────────
# Modo de auth: apikey | jwt | disabled  (default: apikey)
# AUTH_MODE=apikey
#
# Bypass para desenvolvimento — só aceita loopback (127.0.0.1/::1) com role default.
# NUNCA usar em produção / equipa partilhada.
# AUTH_DISABLE=0
# AUTH_DEFAULT_ROLE=admin            # role atribuído quando AUTH_DISABLE=1 + loopback
#
# API keys estáticas (CLI / CI). Formato: "<key>:<role>[:label]" separadas por '|' ou \n
# Roles: viewer | operator | red | admin
# Gera com: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# AUTH_API_KEYS=ABC123XYZ_pelo_menos_24_chars:operator:laptop|DEF456_outra_chave_longa:admin:ci-runner
# AUTH_API_KEYS_FILE=/etc/ghostrecon/api-keys.txt  # alternativa (uma entry por linha)
#
# JWT (HS256 ou RS256). Token tem de incluir claim `role` (viewer|operator|red|admin)
# e opcionalmente `scopes` (array — não pode expandir além do role).
# AUTH_JWT_SECRET=segredo_para_HS256_pelo_menos_32_chars
# AUTH_JWT_PUBLIC_KEY=/etc/ghostrecon/jwt-pub.pem      # ou PEM inline (RS256)
# AUTH_JWT_AUDIENCE=ghostrecon
# AUTH_JWT_ISSUER=https://auth.exemplo.com
#
# Audit log (allow/deny + recon.stream.start) em NDJSON (1 ficheiro por dia).
# AUTH_AUDIT_DIR=./logs                # default: <repo>/logs
# AUTH_AUDIT_DISABLE=0                  # 1 → só stderr (sem ficheiro)
#
# Headers aceites pelos clientes:
#   Authorization: Bearer <jwt-ou-apikey>
#   X-API-Key: <apikey>
# Para ver a matriz role × scope: docs/AUTH-RBAC.md


# Hosts fora de escopo (subs do alvo a ignorar em links / corpus / sitemap). Separados por vírgula ou espaço.
# Suporta wildcard DNS: "*.cdn.cliente.com" bloqueia esse host e subdomínios dele.
# Somam-se à lista da UI (Modules → Aplicar lista fora de escopo) quando esse módulo está ativo.
# GHOSTRECON_OUT_OF_SCOPE=staging.cliente.com,shop.cliente.com,*.legacy.cliente.com

# Common Crawl — URL completa do CDX API (opcional; senão usa collinfo)
# GHOSTRECON_CC_CDX_API=https://index.commoncrawl.org/CC-MAIN-2025-51-index

# SQLite local (só se não usares Supabase)
# GHOSTRECON_DB=

# FTP anonymous login check (modo Kali, quando nmap identifica FTP)
# GHOSTRECON_FTP_ANON_TIMEOUT_MS=12000
# Após login anónimo OK: testa upload STOR + DELE (PASV/EPSV). Desligar: 0
# GHOSTRECON_FTP_WRITE_PROBE=1
# GHOSTRECON_FTP_WRITE_PROBE_TIMEOUT_MS=15000
# Webhook CRITICAL: texto do embed pode ser gerado por IA (Gemini → OpenRouter → LM Studio)
# GHOSTRECON_FTP_CRITICAL_AI=1

# nmap -sV: por cada serviço com versão, enfileira Google «exploit pra <serviço> <versão>» (fila de dorks na UI)
# GHOSTRECON_EXPLOIT_GOOGLE_MAX_QUERIES=25

# ── Kali mode / wpscan (WordPress enumeration) ──
# Se o passivo detectar WordPress, o Kali mode pode rodar wpscan (apenas enumeração).
# Token da WordPress Vulnerability Database (CVEs no JSON): https://wpscan.com/register
# O CLI também lê WPSCAN_API_TOKEN no ambiente (recomendado).
# WPSCAN_API_TOKEN=
# Alias opcional (mesmo efeito que WPSCAN_API_TOKEN):
# GHOSTRECON_WPSCAN_API_TOKEN=
# xss_vibes (pasta local Xss/xss_vibes) — corre após etapa XSS no Kali quando houver sinais.
# GHOSTRECON_XSS_VIBES_MAX_URLS=25
# GHOSTRECON_XSS_VIBES_THREADS=6
# GHOSTRECON_XSS_VIBES_TIMEOUT_MS=300000
# Por defeito o GHOSTRECON não executa wpscan sem token. Para permitir scan só com enumeração (sem WPVulnDB):
# GHOSTRECON_WPSCAN_REQUIRE_API=0
# GHOSTRECON_WPSCAN_DETECTION_MODE=mixed
# GHOSTRECON_WPSCAN_TIMEOUT_MS=240000

# Priorização v2 — contexto do programa (JSON; espelha o campo opcional na UI)
# GHOSTRECON_BOUNTY_CONTEXT={"focus":"api","programType":"web"}
# Snapshot JSON completo dos findings em `runs.findings_json` (Postgres: ALTER TABLE runs ADD COLUMN findings_json jsonb;)
# GHOSTRECON_FINDINGS_SNAPSHOT_MAX_BYTES=8000000
# Playwright — verificação DOM opcional de XSS (requer: npm install playwright + npx playwright install chromium)
# GHOSTRECON_PLAYWRIGHT_XSS=1
# GHOSTRECON_PLAYWRIGHT_XSS_MAX=4
# Recheck HTTP rápido em achados HIGH / HIGH_PROBABILITY
# GHOSTRECON_HIGH_RECHECK_MAX=20

# ─────────────────────────
# AUTENTICAÇÃO - GUIA COMPLETO
# ─────────────────────────
# O GHOSTRECON usa autenticação por API Key por padrão. Sem chaves configuradas,
# todas as rotas privilegiadas retornam 401 (Unauthorized).
#
# COMO GERAR UMA CHAVE:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
#
# FORMATO DAS CHAVES:
#   <key>:<role>[:label]
#   - key: a chave gerada (mínimo 24 caracteres)
#   - role: viewer | operator | red | admin
#   - label: opcional, para identificação (ex: laptop, ci-runner)
#
# ROLES E PERMISSÕES:
#   viewer    → apenas leitura (recon.read)
#   operator  → viewer + recon.run, brain.write, notes.write, validation.write
#   red       → operator + recon.intrusive, ai.run, shannon.run, project.write
#   admin     → acesso total (wildcard '*')
#
# EXEMPLOS:
#   # Uma chave de admin (acesso total)
#   AUTH_API_KEYS=sua-chave-gerada:admin:laptop
#
#   # Múltiplas chaves separadas por |
#   AUTH_API_KEYS=chave1:red:laptop|chave2:admin:ci-runner|chave3:viewer:readonly
#
#   # Alternativa: arquivo externo (uma chave por linha)
#   AUTH_API_KEYS_FILE=/etc/ghostrecon/api-keys.txt
#
# COMO USAR NA REQUISIÇÃO:
#   curl -H "Authorization: Bearer <sua-chave>" http://127.0.0.1:3847/api/recon/...
#   # ou
#   curl -H "X-API-Key: <sua-chave>" http://127.0.0.1:3847/api/recon/...
#
# DESABILITAR AUTENTICAÇÃO (APENAS DESENVOLVIMENTO LOCAL):
#   AUTH_MODE=disabled
#   # AVISO: só funciona para pedidos vindos de 127.0.0.1/::1
#
# JWT (alternativa a API keys):
#   AUTH_MODE=jwt
#   AUTH_JWT_SECRET=segredo_para_HS256_pelo_menos_32_chars
#   # O token JWT deve conter claim "role" (viewer|operator|red|admin)
